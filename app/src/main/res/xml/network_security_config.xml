<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config>
        <domain includeSubdomains="true">sberbank.ru</domain>
        <domain includeSubdomains="true">giga.chat</domain>

        <trust-anchors>
            <certificates src="@raw/russian_ca" />
            <certificates src="@raw/russian_ca_gost" />
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <base-config>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>